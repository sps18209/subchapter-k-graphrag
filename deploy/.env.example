# Copy to .env and fill in real values. NEVER commit .env.
# docker compose substitutes these via ${VAR}.

# --- API ---
# Comma-separated API keys, "label:key" or a bare "key". UNSET = OPEN (laptop/dev only).
# Generate one: openssl rand -hex 24
SUBK_API_KEYS=firm:replace-with-a-long-random-secret
# Allowed CORS origins for a browser frontend (comma-separated). "*" is dev only.
SUBK_CORS_ORIGINS=*
# Host port to publish the API on.
API_PORT=8000

# --- Auth: OIDC mode (real identity; overrides api-key when both are set) ---
# Verify JWTs from your identity provider. Needs requirements-oidc.txt installed.
# Get ISSUER + AUDIENCE from your IdP (Auth0 / Entra ID / Google / Okta / Cognito).
# SUBK_OIDC_ISSUER=https://YOUR_TENANT.us.auth0.com/    # issuer URL (match your IdP exactly)
# SUBK_OIDC_AUDIENCE=https://api.your-firm.com          # the API identifier / audience
# SUBK_OIDC_JWKS_URL=                                   # optional; auto-discovered from issuer
# SUBK_OIDC_ORG_CLAIM=org_id                            # claim carrying the tenant/org

# --- Audit (hash-chained, tamper-evident) ---
# Append records to this file (still also to stdout). Verify: python audit.py verify <file>.
# In production point the sink at a WORM bucket / append-only Postgres (see DEPLOY.md).
# SUBK_AUDIT_LOG=/var/log/subk/audit.jsonl

# --- Postgres (production store; see DEPLOY.md) ---
POSTGRES_USER=subk
POSTGRES_PASSWORD=replace-with-a-long-random-secret
POSTGRES_DB=subk
# DATABASE_URL is COMMENTED OUT so the API boots on SQLite with zero setup.
# To serve from Postgres: (1) start the stack, (2) load the store with
#   docker compose --profile tools run --rm migrate
# then (3) uncomment the line below and restart the api. Inside compose this resolves to
# the `db` service; point it at a managed provider (Supabase/Neon/RDS/Cloud SQL) instead
# by changing the host. The migrate service derives this URL from POSTGRES_* on its own,
# so migration works whether or not this line is set.
# DATABASE_URL=postgresql://subk:replace-with-a-long-random-secret@db:5432/subk

# --- Hybrid retrieval (Layer 3, swap #2) ---
# Fuses a dense (embedding) seed with BM25. Unset = BM25-only (default, no deps).
#   hashing = pure-stdlib offline stand-in (no key, no pgvector needed to serve)
#   openai  = real semantic embeddings (needs OPENAI_API_KEY; use no-train / zero-retention)
# When set AND migrating to Postgres, migrate also stores vectors in a pgvector column
# (needs the `vector` extension on the server — Supabase/Neon have it).
# SUBK_EMBED_PROVIDER=hashing
# SUBK_EMBED_DIM=256                  # hashing only; must match the migrated pgvector column
# OPENAI_API_KEY=sk-...               # required for SUBK_EMBED_PROVIDER=openai
# SUBK_EMBED_MODEL=text-embedding-3-small

# --- Gated enrichment (Layer 2, swap #3) ---
# Drafts plain-language glosses for ATTORNEY REVIEW; drafts are never written to the graph
# until promoted. Unset = disabled (default). Read "Before you add an LLM API key" in
# DEPLOY.md before enabling openai. Enrichment sends ONLY public corpus text (low risk).
#   stub   = offline, deterministic, no key   |   openai = real drafts (needs OPENAI_API_KEY)
# SUBK_ENRICH_PROVIDER=stub
# SUBK_ENRICH_MODEL=gpt-4o-mini       # for SUBK_ENRICH_PROVIDER=openai

# --- Citation verification ---
# Structural + corpus check runs always (offline). SUBK_CITE_PROVIDER=online adds a live
# check against the AUTHORITATIVE primary source per citation type:
#   regulation            -> eCFR (also returns the 'up to date as of' date)
#   statute / IRC         -> US Code (Cornell LII)
#   X FR Y                -> Federal Register
#   Rev. Rul./Proc./Notice-> IRS (irs.gov recent-guidance folder)
#   case                  -> CourtListener (the ONLY type that needs a key)
# Everything except cases needs NO key.
# SUBK_CITE_PROVIDER=online
# COURTLISTENER_TOKEN=                 # OPTIONAL — only for verifying CASE citations

# --- Proposed-legislation horizon scan (python/horizon.py) ---
# SEPARATE from the authority graph: surfaces PENDING federal tax bills (govinfo / Congress.gov).
# Bills are NOT law and never enter the graph. Works with the shared DEMO_KEY out of the box;
# set a free key (api.data.gov) only for higher rate limits.
# GOVINFO_API_KEY=

# --- Natural-language assistant (python/assistant.py) ---
# Routes plain English to a tool; the engine still produces every answer. Unset = rules
# (no model). For a private local model: install Ollama, `ollama pull llama3.2:3b`, then:
# SUBK_ASSISTANT_PROVIDER=ollama       # local; nothing you type leaves the machine
# SUBK_ASSISTANT_MODEL=llama3.2:3b     # any Ollama model (or an OpenAI model for openai mode)
# OLLAMA_URL=http://localhost:11434
# SUBK_ASSISTANT_PROVIDER=openai       # alternative: uses OPENAI_API_KEY (sends your text out)
# With a model on, each answer shows a plain-English summary ABOVE the verified engine
# output. The summary is GROUNDED in the live primary-source text (eCFR/US Code) of the
# authorities the engine cited — the model may use only that text + the engine result.
# To show only the raw verified output (no model summary):           SUBK_ASSISTANT_EXPLAIN=0
# To keep the summary but skip the live grounding fetch (faster):    SUBK_EXPLAIN_GROUNDING=0

# --- SEE analyzer reasoning sandwich (python/subk_analyze.py --run) ---
# Layer A (verified bundle) and Layer B (closure check) are LOCAL. The middle step sends the
# verified bundle to a PINNED Anthropic model; Layer B rejects any reply that introduces law
# not in the bundle. Runs only with --run AND this key set. Rule 1.6: use a no-train /
# zero-data-retention account.
# ANTHROPIC_API_KEY=sk-ant-...
# SUBK_LLM_MODEL=claude-opus-4-8        # pinned by default; override deliberately
# SUBK_LLM_ZDR_CONFIRMED=1              # REQUIRED before --run sends anything: your attestation
#                                       # that the account is no-train / zero-data-retention
# SUBK_LLM_MASK=0                       # disable identifier masking (ON by default — masks
#                                       # entity names / EIN / SSN / amounts / email / phone)
# SUBK_EGRESS_LOG=                      # path for the local egress-audit log (default
#                                       # ~/subk-matters/.egress-log.jsonl). Records every send:
#                                       # timestamp, provider/model, sha256 of the SCRUBBED payload,
#                                       # role labels + redaction counts (never real names), chain hash.
